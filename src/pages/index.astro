---
import MainLayout from "@/layout/MainLayout.astro";
import { ArrowRight, MapPinned } from "lucide-react";
---

<MainLayout
    title="Travily - Book Flights Effortlessly"
    description="Travily - Book flights effortlessly with our modern travel
platform"
noindex={false}
>
    <h1>Astro</h1>

<section class="mx-auto max-w-6xl px-4 py-12">
  <div class="mb-6 flex items-end justify-between gap-4">
    <div>
      <p class="text-sm font-medium text-muted-foreground">Travel tips</p>
      <h2 class="text-3xl font-bold tracking-tight">Guides to make travel easier</h2>
    </div>

    <a
      href="/travel-tips"
      class="hidden items-center gap-2 text-sm font-medium text-primary underline-offset-4 hover:underline sm:inline-flex"
    >
      View all tips
      <ArrowRight className="h-4 w-4" />
    </a>
  </div>

  <a
    href="/travel-tips"
    class="group block overflow-hidden rounded-2xl border bg-background shadow-sm transition hover:-translate-y-1 hover:shadow-lg"
  >
    <div class="grid gap-0 md:grid-cols-[1.2fr_0.8fr]">
      <div class="p-6 sm:p-8">
        <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-primary/10 px-3 py-1 text-sm font-medium text-primary">
          <MapPinned className="h-4 w-4" />
          Travel guide
        </div>

        <h3 class="text-2xl font-semibold tracking-tight">
          Smart travel tips for smoother trips
        </h3>

        <p class="mt-3 max-w-xl text-sm leading-6 text-muted-foreground">
          Discover practical guides for packing, saving money, booking smarter, and getting around with less stress.
        </p>

        <div class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-primary">
          Read the travel tips
          <ArrowRight className="h-4 w-4 transition-transform group-hover:translate-x-1" />
        </div>
      </div>

      <div class="flex items-center justify-center bg-muted p-6 sm:p-8">
        <div class="grid w-full grid-cols-2 gap-3">
          <div class="rounded-xl bg-background p-4 shadow-sm">
            <p class="text-xs text-muted-foreground">Packing</p>
            <p class="mt-1 font-medium">Travel light</p>
          </div>
          <div class="rounded-xl bg-background p-4 shadow-sm">
            <p class="text-xs text-muted-foreground">Budget</p>
            <p class="mt-1 font-medium">Save more</p>
          </div>
          <div class="rounded-xl bg-background p-4 shadow-sm">
            <p class="text-xs text-muted-foreground">Booking</p>
            <p class="mt-1 font-medium">Plan smarter</p>
          </div>
          <div class="rounded-xl bg-background p-4 shadow-sm">
            <p class="text-xs text-muted-foreground">Safety</p>
            <p class="mt-1 font-medium">Travel calmly</p>
          </div>
        </div>
      </div>
    </div>
  </a>

  <a
    href="/travel-tips"
    class="mt-4 flex items-center justify-center gap-2 rounded-xl border bg-background px-4 py-3 text-sm font-medium text-primary shadow-sm transition hover:bg-muted sm:hidden"
  >
    View all travel tips
    <ArrowRight className="h-4 w-4" />
  </a>
</section>
</MainLayout>
